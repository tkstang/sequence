# Sequence web-mvp — environment variable reference (no real values here)
#
# Real files (gitignored):
#   packages/api/.env        — API server (created in p01/p03)
#   apps/web/.env.local      — Next.js app
#   shell env or root .env   — deploy credentials (never committed)
#
# See .oat/repo/reference/planning/2026-rewrite/preflight-steps.md for setup steps.

# ── packages/api/.env ────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@host.us-east-1.aws.neon.tech/db   # Neon DIRECT string (not -pooler)
DATABASE_URL_TEST=postgres://user:pass@host/db                      # Neon test branch (integration suite resets it)
BETTER_AUTH_SECRET=change-me                                        # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
PORT=3001
# Optional social auth (feature is config-gated by presence):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── apps/web/.env.local ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── deploy credentials (shell env; used in p07) ──────────────────
RAILWAY_TOKEN=
VERCEL_TOKEN=
