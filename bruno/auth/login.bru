meta {
  name: login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/sign-in/email
  body: json
  auth: none
}

headers {
  content-type: application/json
  origin: {{webOrigin}}
}

body:json {
  {
    "email": "{{email}}",
    "password": "supersecret123"
  }
}

assert {
  res.status: eq 200
  res.body.user.email: eq {{email}}
}
