{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "packages/api/Dockerfile",
    "watchPatterns": [
      "packages/api/**",
      "packages/game-logic/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @sequence/api start",
    "preDeployCommand": "pnpm --filter @sequence/api exec drizzle-kit migrate",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "sleepApplication": false,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "region": "us-east4-eqdc4a"
  }
}
