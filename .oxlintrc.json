{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "react-perf",
    "jsx-a11y",
    "import",
    "nextjs"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {},
  "ignorePatterns": [
    "**/dist/**",
    "**/.next/**",
    "**/drizzle/**",
    "**/*.config.*",
    "node_modules"
  ]
}
